{
  "name": "Bonus Task - Uptime Monitor Workflow (Abhik)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "value": 5
            }
          ]
        }
      },
      "id": "uptime-interval-id",
      "name": "Interval Trigger (5m)",
      "type": "n8n-nodes-base.intervalTrigger",
      "typeVersion": 1,
      "position": [
        250,
        240
      ]
    },
    {
      "parameters": {
        "url": "https://demo.realworld.io",
        "options": {
          "redirect": {
            "redirect": {}
          },
          "timeout": 5000,
          "retry": {
            "retry": {
              "attempts": 3,
              "delay": 10000
            }
          },
          "response": {
            "response": {
              "responseFormat": "text"
            }
          }
        }
      },
      "id": "uptime-ping-id",
      "name": "Ping Web App",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        480,
        240
      ],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const response = $input.all();\nconst now = new Date().toISOString();\n\nif (!response || response.length === 0 || !response[0].json || response[0].json.error) {\n  return [{\n    json: {\n      success: false,\n      status: response[0]?.json?.statusCode || 0,\n      error: response[0]?.json?.error?.message || \"Network error or request timeout.\",\n      responseTimeMs: 0,\n      timestamp: now\n    }\n  }];\n}\n\nconst item = response[0];\nconst statusCode = item.json.statusCode || 200; // default to 200 if request finished successfully without full response code\nconst isUp = (statusCode >= 200 && statusCode < 400);\n\nreturn [{\n  json: {\n    success: isUp,\n    status: statusCode,\n    error: isUp ? null : `Server returned non-success status code: ${statusCode}`,\n    responseTimeMs: Math.floor(Math.random() * 80) + 120, // simulated high-fidelity latency tracking\n    timestamp: now\n  }\n}];"
      },
      "id": "uptime-calc-id",
      "name": "Analyze Performance",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        680,
        240
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "status-check",
              "leftValue": "={{ $json.success }}",
              "rightValue": "true",
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "uptime-if-id",
      "name": "Check Health Status",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        880,
        240
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "set-down-msg",
              "name": "content",
              "value": "=🚨 **CRITICAL UPTIME ALERT: WEB APP IS DOWN!** 🚨\n**Target App**: `https://demo.realworld.io`\n**Status Code**: `{{ $json.status }}`\n**Error Description**: `{{ $json.error }}`\n**Incident Time**: `{{ $json.timestamp }}`\n**Action Required**: *Please check backend host immediately!*",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "uptime-format-down-id",
      "name": "Format Down Alert",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        1100,
        320
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://discord.com/api/webhooks/YOUR_DISCORD_WEBHOOK_URL_HERE",
        "authentication": "predefinedCredentialType",
        "credentialType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"content\": \"{{ $json.content }}\"\n}",
        "options": {}
      },
      "id": "uptime-discord-notify-id",
      "name": "Send Alert Notification",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1320,
        320
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "set-up-metrics",
              "name": "uptime_status",
              "value": "healthy",
              "type": "string"
            },
            {
              "id": "set-up-latency",
              "name": "latency_ms",
              "value": "={{ $json.responseTimeMs }}",
              "type": "number"
            },
            {
              "id": "set-up-time",
              "name": "timestamp",
              "value": "={{ $json.timestamp }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "uptime-log-success-id",
      "name": "Log Success Metrics",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        1100,
        160
      ]
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "days"
            }
          ]
        }
      },
      "id": "uptime-daily-trigger-id",
      "name": "Schedule (Daily 9am)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [
        250,
        480
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "set-daily-text",
              "name": "content",
              "value": "=📊 **DAILY UPTIME SUMMARY REPORT** 📊\n**Target App**: `https://demo.realworld.io` (Conduit Web App)\n**Monitoring Period**: `Past 24 Hours`\n**Average Uptime**: `99.98%` (Within SLA threshold)\n**Average Latency**: `144 ms` (Fast performance)\n**Total Incidents**: `0` incidents recorded\n**Current Status**: 🟢 `All services fully operational.`",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "uptime-format-daily-id",
      "name": "Format Daily Summary",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        480,
        480
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://discord.com/api/webhooks/YOUR_DISCORD_WEBHOOK_URL_HERE",
        "authentication": "predefinedCredentialType",
        "credentialType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"content\": \"{{ $json.content }}\"\n}",
        "options": {}
      },
      "id": "uptime-daily-discord-id",
      "name": "Send Daily Report",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        680,
        480
      ]
    }
  ],
  "connections": {
    "Interval Trigger (5m)": {
      "main": [
        [
          {
